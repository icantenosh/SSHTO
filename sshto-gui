        self.tree.configure(yscrollcommand=scrollbar.set)
        self.tree.bind("<Double-1>", lambda _event: self.connect_selected())
        self.tree.bind("<Return>", lambda _event: self.connect_selected())
        self.tree.bind("<Delete>", lambda _event: self.remove_selected())

        status = ttk.Label(main, textvariable=self.status_var, style="Status.TLabel", anchor="w")
        status.pack(fill=tk.X, pady=(10, 0))

    def change_theme(self) -> None:
        write_json(self.theme_path, {"theme": self.theme_var.get()})
        self.configure_styles()
        self.root.configure(bg=self.palette()["bg"])
        self.populate()
        self.status_var.set(f"Theme: {self.theme_var.get()}")

    def show_message(self, text: str, kind: str = "info") -> None:
        MessageDialog(self, text, kind).show()

    def confirm(self, text: str) -> bool:
        return bool(ConfirmDialog(self, text).show())

    def reload(self) -> None:
        self.app_dir.mkdir(parents=True, exist_ok=True)
        if not self.servers_path.exists():
            write_json(self.servers_path, {})
        try:
            data = load_json(self.servers_path, {})
        except RuntimeError as exc:
            self.show_message(str(exc), "error")
            data = {}
        self.servers = {name: value for name, value in data.items() if isinstance(value, dict)}
        self.populate()
        self.status_var.set(f"Loaded {len(self.servers)} saved server(s) from {self.servers_path}")

    def save_servers(self) -> None:
        write_json(self.servers_path, self.servers)
        self.populate()

    def populate(self) -> None:
        colors = self.palette()
        self.tree.tag_configure("even", background=colors["entry"], foreground=colors["ink"])
        self.tree.tag_configure("odd", background=colors["row_odd"], foreground=colors["ink"])
        query = self.search_var.get().strip().lower()
        selected = self.selected_name()
        self.tree.delete(*self.tree.get_children())
        for index, name in enumerate(sorted(self.servers)):
            item = self.servers[name]
            target = str(item.get("target", ""))
            port = str(item.get("port", "22"))
            haystack = f"{name} {target} {port}".lower()
            if query and query not in haystack:
                continue
            tag = "even" if index % 2 == 0 else "odd"
            self.tree.insert("", tk.END, iid=name, values=(name, target, port), tags=(tag,))
        if selected and self.tree.exists(selected):
            self.tree.selection_set(selected)

    def selected_name(self) -> str | None:
        selection = self.tree.selection() if hasattr(self, "tree") else ()
        return selection[0] if selection else None

    def require_selection(self) -> str | None:
        name = self.selected_name()
        if not name:
            self.show_message("Select a saved server first.")
            return None
        return name

    def add_server(self) -> None:
        result = ServerDialog(self, "Add Server").show()
        if not result:
            return
        name = result.pop("name")
        self.servers[name] = result
        self.save_servers()
        self.tree.selection_set(name)
        self.status_var.set(f"Saved {name}")

    def edit_selected(self) -> None:
        name = self.require_selection()
        if not name:
            return
        item = self.servers[name]
        values = {"name": name, "target": str(item.get("target", "")), "port": str(item.get("port", "22"))}
        result = ServerDialog(self, "Edit Server", values).show()
        if not result:
            return
        new_name = result.pop("name")
        if new_name != name:
            self.servers.pop(name, None)
        self.servers[new_name] = result
        self.save_servers()
        self.tree.selection_set(new_name)
        self.status_var.set(f"Updated {new_name}")

    def remove_selected(self) -> None:
        name = self.require_selection()
        if not name:
            return
        if not self.confirm(f"Remove '{name}'?"):
            return
        self.servers.pop(name, None)
        self.save_servers()
        self.status_var.set(f"Removed {name}")

    def connect_selected(self) -> None:
        name = self.require_selection()
        if name:
            self.run_in_terminal(["ssh", "-p", str(self.servers[name].get("port", "22")), str(self.servers[name].get("target", ""))])

    def keysetup_selected(self) -> None:
        name = self.require_selection()
        if not name:
            return
        item = self.servers[name]
        target = str(item.get("target", ""))
        port = str(item.get("port", "22"))
        parsed = split_target(target)
        if not parsed:
            self.show_message("Target must look like user@host.", "error")
            return
        if paramiko is None:
            self.show_message("Internal key setup needs Paramiko. Reinstall SSHTO GUI with install-gui.sh.", "error")
            return

        user, host = parsed
        password = PasswordDialog(self, f"Password for {target}").show()
        if password is None:
            return

        self.status_var.set(f"Installing SSH key on {name}...")
        self.root.update_idletasks()
        try:
            key_path = public_key_path()
            public_key = key_path.read_text(encoding="utf-8").strip()
            self.install_public_key(host, user, int(port), password, public_key)
        except Exception as exc:
            self.show_message(f"Key setup failed:\n{exc}", "error")
            self.status_var.set("Key setup failed")
            return
        self.show_message(f"SSH key installed for {name}.")
        self.status_var.set(f"SSH key installed for {name}")

    def install_public_key(self, host: str, user: str, port: int, password: str, public_key: str) -> None:
        client = paramiko.SSHClient()
        client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        try:
            client.connect(hostname=host, port=port, username=user, password=password, timeout=20, look_for_keys=False, allow_agent=False)
            command = (
                "sh -c 'read -r key; umask 077; mkdir -p ~/.ssh; touch ~/.ssh/authorized_keys; "
                "grep -qxF \"$key\" ~/.ssh/authorized_keys || printf \"%s\\n\" \"$key\" >> ~/.ssh/authorized_keys; "
                "chmod 700 ~/.ssh; chmod 600 ~/.ssh/authorized_keys'"
            )
            stdin, stdout, stderr = client.exec_command(command)
            stdin.write(public_key + "\n")
            stdin.channel.shutdown_write()
            exit_status = stdout.channel.recv_exit_status()
            if exit_status != 0:
                error = stderr.read().decode("utf-8", "replace").strip()
                raise RuntimeError(error or f"remote command exited with status {exit_status}")
        finally:
            client.close()

    def run_in_terminal(self, command: list[str]) -> None:
        full_command = terminal_command(command)
        if not full_command:
            self.show_message("No supported terminal emulator was found.\n\nRun this manually:\n" + " ".join(command), "error")
            return
        try:
            subprocess.Popen(full_command)
            self.status_var.set("Started: " + " ".join(command))
        except OSError as exc:
            self.show_message(f"Could not start command:\n{exc}", "error")


def main() -> int:
    try:
        root = tk.Tk()
    except tk.TclError as exc:
        print(f"sshto-gui: could not start Tk: {exc}", file=sys.stderr)
        return 1
    SshtoGui(root)
    root.mainloop()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
