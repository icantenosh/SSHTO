def config_dir() -> Path:
    system = platform.system()
    if system == "Windows":
        base = os.environ.get("APPDATA")
        return Path(base) / CONFIG_NAME if base else Path.home() / CONFIG_NAME
    if system == "Darwin":
        return Path.home() / "Library" / "Application Support" / CONFIG_NAME
    return Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / CONFIG_NAME


def load_json(path: Path, default):
    try:
        if not path.exists():
            return default
        return json.loads(path.read_text(encoding="utf-8") or "{}")
    except (OSError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"Could not read {path}: {exc}") from exc


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def valid_port(value: str) -> bool:
    try:
        port = int(value)
    except ValueError:
        return False
    return 1 <= port <= 65535


def split_target(target: str) -> tuple[str, str] | None:
    if "@" not in target:
        return None
    user, host = target.split("@", 1)
    if not user or not host:
        return None
    return user, host


def public_key_path() -> Path:
    ssh_dir = Path.home() / ".ssh"
    ed25519 = ssh_dir / "id_ed25519.pub"
    rsa = ssh_dir / "id_rsa.pub"
    if ed25519.exists():
        return ed25519
    if rsa.exists():
        return rsa

    ssh_dir.mkdir(mode=0o700, exist_ok=True)
    private_key = ssh_dir / "id_ed25519"
    result = subprocess.run(
        ["ssh-keygen", "-t", "ed25519", "-N", "", "-C", f"{getuser()}@{gethostname()}", "-f", str(private_key)],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or "ssh-keygen could not create an SSH key.")
    return ed25519


def terminal_command(command: list[str]) -> list[str] | None:
    system = platform.system()
    if system == "Windows":
        return ["cmd", "/k", *command]
    if system == "Darwin" and shutil.which("osascript"):
        script = " ".join(command)
        return ["osascript", "-e", f'tell app "Terminal" to do script "{script}"']

    joined = " ".join(sh_quote(part) for part in command)
    shell_line = f"{joined}; status=$?; printf '\\nSSHTO session ended with status %s. Press Enter to close...' \"$status\"; read _"
    candidates = [
        ("gnome-terminal", ["gnome-terminal", "--", "sh", "-lc", shell_line]),
        ("konsole", ["konsole", "-e", "sh", "-lc", shell_line]),
        ("xfce4-terminal", ["xfce4-terminal", "-e", f"sh -lc {sh_quote(shell_line)}"]),
        ("mate-terminal", ["mate-terminal", "-e", f"sh -lc {sh_quote(shell_line)}"]),
        ("lxterminal", ["lxterminal", "-e", f"sh -lc {sh_quote(shell_line)}"]),
        ("xterm", ["xterm", "-e", "sh", "-lc", shell_line]),
        ("x-terminal-emulator", ["x-terminal-emulator", "-e", "sh", "-lc", shell_line]),
    ]
    for executable, full_command in candidates:
        if shutil.which(executable):
            return full_command
    return None


def sh_quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"


def font_family(root: tk.Tk, candidates: tuple[str, ...], fallback: str) -> str:
    available = set(tkfont.families(root))
    for family in candidates:
        if family in available:
            return family
    return fallback


class ThemedModal(tk.Toplevel):
    def __init__(self, app: "SshtoGui", title: str):
        super().__init__(app.root)
        self.app = app
        self.colors = app.palette()
        self.result = None
        self.title(title)
        self.configure(bg=self.colors["bg"])
        self.resizable(False, False)
        self.transient(app.root)
        self.grab_set()

        self.content = ttk.Frame(self, padding=16, style="Panel.TFrame")
        self.content.pack(fill=tk.BOTH, expand=True)
        self.bind("<Escape>", lambda _event: self.cancel())
        self.protocol("WM_DELETE_WINDOW", self.cancel)

    def show(self):
        self.update_idletasks()
        parent_x = self.app.root.winfo_rootx()
        parent_y = self.app.root.winfo_rooty()
        parent_w = self.app.root.winfo_width()
        parent_h = self.app.root.winfo_height()
        width = self.winfo_width()
        height = self.winfo_height()
        x = parent_x + max((parent_w - width) // 2, 0)
        y = parent_y + max((parent_h - height) // 2, 0)
        self.geometry(f"+{x}+{y}")
        self.wait_window()
        return self.result

    def button_row(self, ok_text="OK"):
        row = ttk.Frame(self.content, style="Panel.TFrame")
        row.grid(sticky="e", pady=(14, 0), columnspan=2)
        ttk.Button(row, text=ok_text, style="Accent.TButton", command=self.ok).pack(side=tk.RIGHT)
        ttk.Button(row, text="CANCEL", command=self.cancel).pack(side=tk.RIGHT, padx=(0, 8))

    def cancel(self):
        self.result = None
        self.destroy()


class ServerDialog(ThemedModal):
    def __init__(self, app: "SshtoGui", title: str, values: dict[str, str] | None = None):
        self.values = values or {}
        super().__init__(app, title)
        self.build()

    def build(self):
        master = self.content
        ttk.Label(master, text="Nickname").grid(row=0, column=0, sticky="w", padx=(0, 10), pady=6)
        ttk.Label(master, text="Target").grid(row=1, column=0, sticky="w", padx=(0, 10), pady=6)
        ttk.Label(master, text="Port").grid(row=2, column=0, sticky="w", padx=(0, 10), pady=6)

        self.name_var = tk.StringVar(value=self.values.get("name", ""))
        self.target_var = tk.StringVar(value=self.values.get("target", ""))
        self.port_var = tk.StringVar(value=self.values.get("port", "22"))

        self.name_entry = ttk.Entry(master, textvariable=self.name_var, width=34, style="Cyber.TEntry")
        self.target_entry = ttk.Entry(master, textvariable=self.target_var, width=34, style="Cyber.TEntry")
        self.port_entry = ttk.Entry(master, textvariable=self.port_var, width=10, style="Cyber.TEntry")
        self.name_entry.grid(row=0, column=1, sticky="ew", pady=6)
        self.target_entry.grid(row=1, column=1, sticky="ew", pady=6)
        self.port_entry.grid(row=2, column=1, sticky="w", pady=6)
        self.button_row("SAVE")
        self.name_entry.focus_set()

    def ok(self):
        name = self.name_var.get().strip()
        target = self.target_var.get().strip()
        port = self.port_var.get().strip() or "22"
        if not name:
            self.app.show_message("Nickname is required.", "error")
            return
        if not target or "@" not in target:
            self.app.show_message("Target must look like user@host.", "error")
            return
        if not valid_port(port):
            self.app.show_message("Port must be a number from 1 to 65535.", "error")
            return
        self.result = {"name": name, "target": target, "port": str(int(port))}
        self.destroy()


